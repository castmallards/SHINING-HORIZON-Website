backend/shining_horizon.db
backend/*.db-journal
backend/*.db-wal
backend/*.db-shm
backend/*.db.backup-*
backend/*.db.pre_*_backup

# ── Uploads (user-generated content, not code) ────────────────────
backend/uploads/

