# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/

# ── Virtualenvs ───────────────────────────────────────────────────
backend/venv/
venv/
env/
.venv/

