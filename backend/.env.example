# ──────────────────────────────────────────────────────────────────────
# Shining Horizon backend — environment configuration
#
# 1. Copy this file to `.env`            (cp .env.example .env)
# 2. Fill in the REQUIRED values         (anything marked REQUIRED below)
# 3. Never commit `.env`                 (it's in .gitignore)
# 4. For production, also set the values in the "PRODUCTION" sections
# ──────────────────────────────────────────────────────────────────────


# ─── App ──────────────────────────────────────────────────────────────
APP_NAME=Shining Horizon
# DEBUG must be false in production. true enables verbose tracebacks.
DEBUG=false


# ─── Database ─────────────────────────────────────────────────────────
# SQLite is fine for sites < 500k rows / single server.
DATABASE_URL=sqlite:///./shining_horizon.db
#
# Switch to PostgreSQL once you outgrow SQLite (concurrent writes, multi-server).
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/shining_horizon


# ─── Authentication (REQUIRED) ────────────────────────────────────────
# Generate ONCE with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# Must be at least 32 chars. App refuses to start with the placeholder value.
# Treat this like a password — rotating it logs every admin out.
SECRET_KEY=CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING

# JWT signing algorithm. Don't change unless you know why.
ALGORITHM=HS256

# How long admin sessions last (in minutes). 1440 = 24 hours.
ACCESS_TOKEN_EXPIRE_MINUTES=1440


# ─── Cookies ──────────────────────────────────────────────────────────
# COOKIE_SECURE=true  → cookies only sent over HTTPS. ALWAYS true in production.
# COOKIE_SECURE=false → allowed for local http://localhost dev only.
COOKIE_SECURE=false

# Apex domain so the cookie works on www. and the apex.
# Leave blank for localhost.
# Production example:  COOKIE_DOMAIN=shininghorizon.com
COOKIE_DOMAIN=


# ─── Uploads ──────────────────────────────────────────────────────────
# Folder under backend/ that stores uploaded media + image variants.
UPLOAD_DIR=uploads
# Max single-file upload size in BYTES. 5 MB is enough for product images.
MAX_UPLOAD_SIZE=5242880


# ─── CORS (REQUIRED in production) ────────────────────────────────────
# Comma-separated list of EXACT origins allowed to call the API from a browser.
# Wildcard "*" is rejected on startup — list real origins only.
#
# Dev:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# Production example:
# ALLOWED_ORIGINS=https://shininghorizon.com,https://www.shininghorizon.com


# ─── Security headers (production HTTPS) ──────────────────────────────
# Turn HSTS on ONLY when the site is reachable exclusively over HTTPS.
# Once a browser sees HSTS, it refuses HTTP for HSTS_MAX_AGE seconds — turning
# it on with a broken cert will break the site for users.
ENABLE_HSTS=false
HSTS_MAX_AGE=31536000        # 1 year


# ─── Rate limiting ────────────────────────────────────────────────────
# slowapi syntax: "<count>/<window>" — e.g. "5/15minutes", "20/hour".
# Applied to POST /api/auth/login per client IP. Behind Nginx the IP is
# read from X-Forwarded-For (configured by uvicorn --proxy-headers).
LOGIN_RATE_LIMIT=5/15minutes
